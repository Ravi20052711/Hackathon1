# ============================================================
# THREAT INTEL FUSION ENGINE - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Supabase Configuration ---
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Application Settings ---
SECRET_KEY=your-super-secret-key-change-this-in-production  # Used for JWT signing
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# --- Threat Intel API Keys (Free Tiers) ---
# VirusTotal: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your-vt-api-key

# AbuseIPDB: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# AlienVault OTX: https://otx.alienvault.com/
OTX_API_KEY=your-otx-api-key

# --- OpenAI (for LLM threat summaries) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# --- Redis (for caching & deduplication) ---
# Local Redis: redis://localhost:6379
# Redis Cloud free tier: https://redis.com/try-free/
REDIS_URL=redis://localhost:6379

# --- App Config ---
APP_NAME=ThreatIntelFusion
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- TAXII Feed (optional - public feeds) ---
TAXII_SERVER_URL=https://cti-taxii.mitre.org/taxii/
TAXII_COLLECTION=enterprise-attack
